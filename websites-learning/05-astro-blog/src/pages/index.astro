---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog"))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
---

<BaseLayout title="Astro Notes — Home" description="A static blog built with Astro.">
  <section class="hero">
    <p class="eyebrow">Hello, world</p>
    <h1>A fast static blog built with Astro.</h1>
    <p class="lead">
      Zero JavaScript ships by default. Content lives in Markdown. Pages are statically generated
      and ready for GitHub Pages.
    </p>
    <p>
      <a class="btn" href={`${import.meta.env.BASE_URL}blog/`}>Read the blog →</a>
    </p>
  </section>

  <hr />

  <section>
    <h2>Latest posts</h2>
    <ul class="post-list">
      {posts.map(post => (
        <li>
          <a href={`${import.meta.env.BASE_URL}blog/${post.slug}/`}>{post.data.title}</a>
          <span class="date">{post.data.date.toLocaleDateString(undefined, { year: "numeric", month: "short", day: "numeric" })}</span>
        </li>
      ))}
    </ul>
  </section>
</BaseLayout>

<style>
  .hero { padding: 24px 0; }
  .eyebrow {
    color: var(--accent);
    font-weight: 600;
    font-size: .85rem;
    letter-spacing: .05em;
    text-transform: uppercase;
    margin: 0 0 6px;
  }
  h1 {
    font-size: clamp(2rem, 4vw, 2.8rem);
    margin: 0 0 16px;
    background: linear-gradient(120deg, #db2777, #f59e0b);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  .lead { color: var(--muted); font-size: 1.1rem; max-width: 60ch; }

  .btn {
    display: inline-block;
    background: var(--accent);
    color: #fff;
    padding: 10px 20px;
    border-radius: 8px;
    font-weight: 600;
  }
  .btn:hover { background: var(--accent-hover); text-decoration: none; }

  .post-list { list-style: none; padding: 0; }
  .post-list li {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 12px;
    padding: 12px 0;
    border-bottom: 1px solid var(--border);
  }
  .post-list li:last-child { border-bottom: none; }
  .post-list a { font-weight: 500; }
  .date { color: var(--muted); font-size: .85rem; white-space: nowrap; }
</style>
